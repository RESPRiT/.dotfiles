# Prepend to PATH only if not already present (avoids stacking on reload)
path_prepend() {
  case ":$PATH:" in
    *:"$1":*) ;;
    *) export PATH="$1:$PATH" ;;
  esac
}

# SSH agent (keychain) — prefer per-user binary (~/.local/bin/keychain, installed
# by install.sh) but fall back to system-wide keychain if available.
# Load the standard key plus the signing key (used for git commit signing).
# Per-host keys (e.g. alt/id_ed25519_alt) belong in ~/.shellrc.local.
_keychain_bin=""
if [ -x "$HOME/.local/bin/keychain" ]; then
  _keychain_bin="$HOME/.local/bin/keychain"
elif command -v keychain >/dev/null 2>&1; then
  _keychain_bin="keychain"
fi
if [ -n "$_keychain_bin" ]; then
  # Build key list via positional params (avoids zsh word-split difference).
  set --
  for _k in id_ed25519 id_ed25519_sign; do
    [ -f "$HOME/.ssh/$_k" ] && set -- "$@" "$_k"
  done
  [ $# -gt 0 ] && eval "$("$_keychain_bin" --eval "$@")"
  unset _k
fi
# _keychain_bin is cleaned up after ~/.shellrc.local (which may reuse it)

# Resolve where the dotfiles repo lives by following the ~/.shellrc symlink.
# install.sh always symlinks ~/.shellrc to <repo>/shellrc (with an absolute
# target), so the parent of the link target is the repo root. Falls back to
# ~/.dotfiles if ~/.shellrc isn't a symlink (e.g., copied rather than linked).
if [ -L "$HOME/.shellrc" ]; then
  _dotfiles_dir=$(cd "$HOME" 2>/dev/null && cd "$(dirname "$(readlink "$HOME/.shellrc")")" 2>/dev/null && pwd)
fi
: "${_dotfiles_dir:=$HOME/.dotfiles}"

# Auto-update a git repo from its upstream. Used by dotfiles and ~/.docs
# (set DOTFILES_AUTO_UPDATE=1 / DOCS_AUTO_UPDATE=1 in ~/.zshrc.local or ~/.bashrc.local).
# Args: <label> <repo-dir>
_repo_auto_update() {
  local label="$1" repo="$2"
  local backup="$repo/backup"
  local msg="$repo/.update-msg"

  GIT_TERMINAL_PROMPT=0 git -C "$repo" fetch --quiet 2>/dev/null || return

  local changed
  changed=$(git -C "$repo" diff --name-only HEAD..@{u} 2>/dev/null)
  [ -z "$changed" ] && return

  local commit_count plural=""
  commit_count=$(git -C "$repo" rev-list --count HEAD..@{u} 2>/dev/null)
  [ "$commit_count" != "1" ] && plural="s"

  local timestamp
  timestamp=$(date +%s)
  mkdir -p "$backup"

  printf '%s\n' "$changed" | while IFS= read -r f; do
    [ -f "$repo/$f" ] || continue
    local bname="${f//\//_}"
    cp "$repo/$f" "$backup/${bname}.${timestamp}.bak"
    local count=$(ls "$backup/${bname}".*.bak 2>/dev/null | wc -l)
    if [ "$count" -gt 5 ]; then
      ls "$backup/${bname}".*.bak 2>/dev/null | sort | head -n $(( count - 5 )) | while IFS= read -r old; do
        rm -f "$old"
      done
    fi
  done

  GIT_TERMINAL_PROMPT=0 git -C "$repo" pull --ff-only --quiet 2>/dev/null \
    && printf '\033[1;34m[%s]\033[0m Updated from remote \033[38;5;240m(%s commit%s)\033[0m\n' "$label" "$commit_count" "$plural" > "$msg"
}
# Execution is deferred to zshrc/bashrc (after local rc sets the *_AUTO_UPDATE flags)

# Warn if install.sh hasn't been re-run since the migration system was added.
# Either condition means `git pull` won't trigger pending migrations.
if [ -d "$_dotfiles_dir/.git" ] && \
   { [ ! -L "$_dotfiles_dir/.git/hooks/post-merge" ] || [ ! -f "$_dotfiles_dir/.state/migrated" ]; }; then
  _install_path="$_dotfiles_dir/install.sh"
  case "$_install_path" in
    "$HOME"/*) _install_path="~${_install_path#$HOME}" ;;
  esac
  printf '\033[1;33m[dotfiles]\033[0m You need to run install.sh again to setup migrations \033[38;5;240m(%s)\033[0m\n' "$_install_path" >&2
  unset _install_path
fi

# COLORTERM doesn't survive SSH (sshd only accepts LANG/LC_*), but TERM does.
# Infer truecolor from terminal-specific TERM values before falling back.
# Windows Terminal advertises truecolor but exports neither COLORTERM nor a
# terminal-specific TERM, so detect it via WT_SESSION.
if [ -z "$COLORTERM" ]; then
  case "$TERM" in
    xterm-ghostty|xterm-kitty|alacritty|wezterm) export COLORTERM=truecolor ;;
    tmux-*|screen-*) export COLORTERM=truecolor ;;
    *) [ -n "$WT_SESSION" ] && export COLORTERM=truecolor ;;
  esac
fi

# If the terminfo entry for TERM is missing, fall back to xterm-256color
# (common over SSH when the remote lacks e.g. xterm-ghostty terminfo)
if ! infocmp "$TERM" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

# Claude Code downgrades to 256 colors inside tmux by default
[ -n "$TMUX" ] && export CLAUDE_CODE_TMUX_TRUECOLOR=1

# Colorized ls
export CLICOLOR=1
export LSCOLORS=Exfxcxdxcxegedabagaced

