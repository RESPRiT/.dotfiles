# Prepend to PATH only if not already present (avoids stacking on reload)
path_prepend() {
  case ":$PATH:" in
    *:"$1":*) ;;
    *) export PATH="$1:$PATH" ;;
  esac
}

# SSH agent (keychain) — prefer per-user binary (~/.local/bin/keychain, installed
# by install.sh) but fall back to system-wide keychain if available.
# Load the standard key plus the signing key (used for git commit signing).
# Per-host keys (e.g. alt/id_ed25519_alt) belong in ~/.shellrc.local.
_keychain_bin=""
if [ -x "$HOME/.local/bin/keychain" ]; then
  _keychain_bin="$HOME/.local/bin/keychain"
elif command -v keychain >/dev/null 2>&1; then
  _keychain_bin="keychain"
fi
if [ -n "$_keychain_bin" ]; then
  # Build key list via positional params (avoids zsh word-split difference).
  set --
  for _k in id_ed25519 id_ed25519_sign; do
    [ -f "$HOME/.ssh/$_k" ] && set -- "$@" "$_k"
  done
  [ $# -gt 0 ] && eval "$("$_keychain_bin" --eval "$@")"
  unset _k
fi
# _keychain_bin is cleaned up after ~/.shellrc.local (which may reuse it)

# Resolve where the dotfiles repo lives by following the ~/.shellrc symlink.
# install.sh always symlinks ~/.shellrc to <repo>/shellrc (with an absolute
# target), so the parent of the link target is the repo root. Falls back to
# ~/.dotfiles if ~/.shellrc isn't a symlink (e.g., copied rather than linked).
if [ -L "$HOME/.shellrc" ]; then
  _dotfiles_dir=$(cd "$HOME" 2>/dev/null && cd "$(dirname "$(readlink "$HOME/.shellrc")")" 2>/dev/null && pwd)
fi
: "${_dotfiles_dir:=$HOME/.dotfiles}"

# Run a command with a wall-clock timeout (seconds). Tries GNU `timeout`,
# then `gtimeout` (coreutils on macOS), then perl's alarm-then-exec trick
# (the SIGALRM timer survives exec on macOS and Linux). No-op fallback if
# none are available.
_with_timeout() {
  local secs="$1"; shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$secs" "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$secs" "$@"
  elif command -v perl >/dev/null 2>&1; then
    perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
  else
    "$@"
  fi
}

# Auto-update a git repo from its upstream, asynchronously. Used by dotfiles
# and ~/.docs (set DOTFILES_AUTO_UPDATE=1 / DOCS_AUTO_UPDATE=1 in
# ~/.zshrc.local or ~/.bashrc.local).
#
# The whole fetch+pull+post-merge pipeline runs in a detached background
# subshell, so shell startup is unblocked (~10ms regardless of network).
# If commits get pulled, the headline plus the full pull+post-merge
# transcript is written atomically to .state/notice-<label>; the precmd
# hook below prints and clears it on the next prompt redraw. If nothing's
# pulled, no notice is written and the user sees nothing.
#
# Migration output and failures are captured because the pull's stderr is
# routed into the notice — recovering the visibility property that the
# previous always-sync design provided, without paying the network cost on
# every launch. Concurrent shells that race here can lose to git's index
# lock; the loser writes its own notice with the error and the user sees
# both. Repo data is safe in either case.
#
# Args: <label> <repo-dir>
_repo_auto_update() {
  local label="$1" repo="$2"
  local state="$_dotfiles_dir/.state"
  local notice="$state/notice-$label"
  mkdir -p "$state"

  # Double-subshell detach: outer ( ) exits immediately after launching the
  # backgrounded inner subshell, which is reparented to init. The user's
  # interactive shell never sees a backgrounded job, so no `[N] PID`
  # job-control announcement gets printed.
  (
    (
      # 5s cap on the fetch so a flaky network can't pile up zombies.
      GIT_TERMINAL_PROMPT=0 _with_timeout 5 git -C "$repo" fetch --quiet 2>/dev/null || exit 0

      local cnt
      cnt=$(git -C "$repo" rev-list --count HEAD..@{u} 2>/dev/null)
      case "$cnt" in ''|0) exit 0 ;; esac

      # Backup files about to change. Same logic as before; runs before the
      # pull so we capture pre-pull contents.
      local backup="$repo/backup" timestamp
      timestamp=$(date +%s)
      mkdir -p "$backup"
      git -C "$repo" diff --name-only HEAD..@{u} 2>/dev/null | while IFS= read -r f; do
        [ -f "$repo/$f" ] || continue
        local bname="${f//\//_}"
        cp "$repo/$f" "$backup/${bname}.${timestamp}.bak"
        local count
        count=$(ls "$backup/${bname}".*.bak 2>/dev/null | wc -l)
        if [ "$count" -gt 5 ]; then
          ls "$backup/${bname}".*.bak 2>/dev/null | sort | head -n $(( count - 5 )) | while IFS= read -r old; do
            rm -f "$old"
          done
        fi
      done

      # Pull + post-merge: capture into a tmp file, then atomic-mv into place
      # so the precmd hook never sees a half-written notice if the bg subshell
      # is killed mid-write. `--quiet` suppresses git's own "Updating .. Fast-
      # forward .." progress so the notice stays at one line per repo + one
      # line per migration (post-merge prints those, see hooks/post-merge).
      local plural=""
      [ "$cnt" != "1" ] && plural="s"
      {
        printf '\033[1;34m[%s]\033[0m Updated from remote \033[38;5;240m(%s commit%s)\033[0m\n' "$label" "$cnt" "$plural"
        GIT_TERMINAL_PROMPT=0 git -C "$repo" pull --ff-only --quiet 2>&1
      } > "$notice.tmp"
      mv "$notice.tmp" "$notice"
    ) &
  )
}

# Print and clear any pending update notices. Registered as a precmd hook
# (zsh) / appended to PROMPT_COMMAND (bash) below. zsh's default NOMATCH
# would error on the glob *before* the loop body runs, so disable it
# locally; bash's default already expands an unmatched glob to its literal
# form, which the `[ -f ]` guard then rejects. The `.tmp` filter skips
# in-progress notice writes — the bg subshell creates `notice-<label>.tmp`
# first, then atomic-mv's it to `notice-<label>`. Without this filter,
# precmd would race the bg subshell, cat the half-written tmp, and unlink
# it before the mv lands.
_repo_show_notices() {
  [ -n "$ZSH_VERSION" ] && setopt local_options no_nomatch
  local notice
  for notice in "$_dotfiles_dir/.state"/notice-*; do
    [ -f "$notice" ] || continue
    case "$notice" in *.tmp) continue ;; esac
    cat "$notice"
    rm -f "$notice"
  done
}
if [ -n "$ZSH_VERSION" ]; then
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _repo_show_notices
elif [ -n "$BASH_VERSION" ]; then
  PROMPT_COMMAND="_repo_show_notices${PROMPT_COMMAND:+; $PROMPT_COMMAND}"
fi

# Warn if install.sh hasn't been re-run since the migration system was added.
# Either condition means `git pull` won't trigger pending migrations.
if [ -d "$_dotfiles_dir/.git" ] && \
   { [ ! -L "$_dotfiles_dir/.git/hooks/post-merge" ] || [ ! -f "$_dotfiles_dir/.state/migrated" ]; }; then
  _install_path="$_dotfiles_dir/install.sh"
  case "$_install_path" in
    "$HOME"/*) _install_path="~${_install_path#$HOME}" ;;
  esac
  printf '\033[1;33m[dotfiles]\033[0m You need to run install.sh again to setup migrations \033[38;5;240m(%s)\033[0m\n' "$_install_path" >&2
  unset _install_path
elif [ -f "$_dotfiles_dir/.state/migrated" ] && [ -d "$_dotfiles_dir/migrations" ]; then
  # Migration tracker exists, so install.sh has been run. Check whether any
  # migrations newer than the tracker are sitting unapplied (e.g., the user
  # fetched commits without running git pull, or a previous post-merge run
  # bailed). A 0-result is the common case; cost is one cheap glob + cat.
  _last_applied=$(cat "$_dotfiles_dir/.state/migrated" 2>/dev/null)
  _max_migration=0
  for _m in "$_dotfiles_dir"/migrations/[0-9][0-9][0-9]-*.sh; do
    [ -f "$_m" ] || continue
    _n=${_m##*/}; _n=${_n%%-*}; _n=$((10#$_n))
    [ "$_n" -gt "$_max_migration" ] && _max_migration=$_n
  done
  if [ "$_max_migration" -gt "${_last_applied:-0}" ]; then
    _pending=$((_max_migration - _last_applied))
    _plural=s; [ "$_pending" -eq 1 ] && _plural=
    _hook_path="$_dotfiles_dir/hooks/post-merge"
    case "$_hook_path" in
      "$HOME"/*) _hook_path="~${_hook_path#$HOME}" ;;
    esac
    printf '\033[1;33m[dotfiles]\033[0m %d pending migration%s — run \033[1m%s\033[0m to apply\n' "$_pending" "$_plural" "$_hook_path" >&2
    unset _pending _plural _hook_path
  fi
  unset _last_applied _max_migration _m _n
fi

# COLORTERM doesn't survive SSH (sshd only accepts LANG/LC_*), but TERM does.
# Infer truecolor from terminal-specific TERM values before falling back.
# Windows Terminal advertises truecolor but exports neither COLORTERM nor a
# terminal-specific TERM, so detect it via WT_SESSION.
if [ -z "$COLORTERM" ]; then
  case "$TERM" in
    xterm-ghostty|xterm-kitty|alacritty|wezterm) export COLORTERM=truecolor ;;
    tmux-*|screen-*) export COLORTERM=truecolor ;;
    *) [ -n "$WT_SESSION" ] && export COLORTERM=truecolor ;;
  esac
fi

# If the terminfo entry for TERM is missing, fall back to xterm-256color
# (common over SSH when the remote lacks e.g. xterm-ghostty terminfo)
if ! infocmp "$TERM" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

# Claude Code downgrades to 256 colors inside tmux by default
[ -n "$TMUX" ] && export CLAUDE_CODE_TMUX_TRUECOLOR=1

# Colorized ls
export CLICOLOR=1
export LSCOLORS=Exfxcxdxcxegedabagaced

alias ll='ls -la'
alias l='ls -l'

