# Machine-local shared config (tool installs, per-host keys, PATH tweaks).
# Sourced after everything else so overrides win. Shell-specific local config
# goes in ~/.bashrc.local or ~/.zshrc.local instead.
[ -f "$HOME/.shellrc.local" ] && . "$HOME/.shellrc.local"
unset _keychain_bin
