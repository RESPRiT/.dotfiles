  fi
}

# Functions
extract() {
  if [ ! -f "$1" ]; then
    echo "extract: '$1' is not a file" >&2
    return 1
  fi
  case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz)  tar xzf "$1" ;;
    *.tar.xz)  tar xJf "$1" ;;
    *.tar)     tar xf "$1" ;;
    *.bz2)     bunzip2 "$1" ;;
    *.gz)      gunzip "$1" ;;
    *.zip)     unzip "$1" ;;
    *.Z)       uncompress "$1" ;;
    *.7z)      7z x "$1" ;;
    *.rar)     unrar x "$1" ;;
    *) echo "extract: unsupported format '$1'" >&2; return 1 ;;
  esac
}

# Git prompt info (used by both zsh PROMPT and bash PS1)
_git_branch_info() {
  local branch dirty=""
  branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
  git diff --quiet 2>/dev/null || dirty="*"
  [ -z "$dirty" ] && [ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ] && dirty="*"
  local color_code
  if [ -n "$dirty" ]; then
    color_code="210"
  elif [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    color_code="218"
  else
    color_code="2"
  fi
  if [ -n "$ZSH_VERSION" ]; then
    printf ' %%F{%s}(%s%s)%%f' "$color_code" "$dirty" "$branch"
  else
    printf ' \001\033[38;5;%sm\002(%s%s)\001\033[0m\002' "$color_code" "$dirty" "$branch"
  fi
}

# Claude
path_prepend "$HOME/.local/bin"
export ENABLE_LSP_TOOL=1

# Wrap `claude` in a minimal tmux session when launched from a bare shell
# so the TUI gets clean framing (gray status bar, no window list).
# Inside an existing tmux session, run claude directly — the user's
# manual session is intentional and should keep its normal lifecycle.
# Bare `--resume`/`-r` (no session id) also runs unwrapped: the picker
# can re-exec claude into a different project directory, which looks
# like a clean exit to tmux and would destroy the wrapper session
# before the resumed conversation loads.
# `--resume <id>` stays wrapped, but we look up the session's original
# cwd from its JSONL and cd there before launching tmux, so resuming
# from a different directory still lands in the right place.
# Unique PID-suffixed session names avoid duplicate-session errors;
# destroy-unattached on makes the session die as soon as claude exits
# or the terminal closes, matching an unwrapped claude's lifecycle.
claude() {
  # Re-merge ~/.claude/settings.json from base + overlay if the overlay is
  # newer. mtime guard makes the no-op case ~free; full merge is ~30ms.
  # Catches direct edits to settings.local.json that haven't been picked up
  # by install.sh / post-merge yet. See claude-global/merge-settings.sh.
  if [ "$HOME/.claude/settings.local.json" -nt "$HOME/.claude/settings.json" ]; then
    bash "$_dotfiles_dir/claude-global/merge-settings.sh" 2>/dev/null
  fi

  if [ -n "$TMUX" ]; then
    # @claude-running gates a tmux S-Enter → C-j remap that works around a
    # CSI-u Shift+Enter regression in Claude Code 2.1.117+ (see tmux.conf).
    tmux set -p @claude-running 1 2>/dev/null
    command claude "$@"
    local rc=$?
    tmux set -pu @claude-running 2>/dev/null
    return $rc
  fi

  # Detect --resume/-r and its optional session id.
  local _resume_mode="" _resume_id="" _expect_id=0 _arg
  for _arg in "$@"; do
    if [ "$_expect_id" = 1 ]; then
      case "$_arg" in
        -*) _resume_mode="bare" ;;
        *)  _resume_mode="with-id"; _resume_id="$_arg" ;;
      esac
      break
    fi
    case "$_arg" in
      --resume|-r) _expect_id=1 ;;
    esac
  done
  [ "$_expect_id" = 1 ] && [ -z "$_resume_mode" ] && _resume_mode="bare"

  if [ "$_resume_mode" = "bare" ]; then
    command claude "$@"
    return
  fi

  # Resolve the session's original cwd (best-effort; unknown id just falls
  # through to running tmux in the caller's cwd, matching prior behavior).
  local _sess_cwd=""
  if [ "$_resume_mode" = "with-id" ]; then
    local _jsonl
    _jsonl=$(ls "$HOME/.claude/projects"/*/"$_resume_id.jsonl" 2>/dev/null | head -1)
    if [ -n "$_jsonl" ]; then
      _sess_cwd=$(grep -om1 '"cwd":"[^"]*"' "$_jsonl" 2>/dev/null)
      _sess_cwd=${_sess_cwd#'"cwd":"'}
      _sess_cwd=${_sess_cwd%'"'}
    fi
  fi

  local claude_bin
  claude_bin=$(unset -f claude 2>/dev/null; command -v claude) || { echo "claude: not found" >&2; return 127; }
  local cmd="$claude_bin"
  [ $# -gt 0 ] && cmd="$cmd $(printf '%q ' "$@")"
  # Claude's farewell text (resume hint, cost summary) is lost when
  # the tmux session is destroyed. A SessionStart hook in settings.json
  # dumps the session payload to $CLAUDE_EXIT_FILE; we parse the session
  # ID from it after tmux returns. SessionStart (not SessionEnd) because
  # it fires reliably for `claude -c`, `--resume`, `/clear`, and compact —
  # SessionEnd was empirically missing the resume case. The hook's
  # `cat > file` overwrites on each fire, so the file ends up with the
  # most recent session_id (post-/clear or post-compact, if applicable).
  local exit_capture
  exit_capture=$(mktemp "${TMPDIR:-/tmp}/claude-exit.XXXXXX") || return 1
  # `-e` is required (not a plain `VAR=val tmux ...` prefix) because tmux
  # only propagates vars in `update-environment` from the calling shell into
  # new sessions; `CLAUDE_CODE_TMUX_TRUECOLOR` isn't on that list, so it'd
  # be dropped whenever the wrapper attaches to an already-running server.
  # COLORTERM, by contrast, is read at *server* startup by tmux.conf's
  # `%if` block (to add :RGB to terminal-features), so we export it into
  # the subshell that invokes tmux — making the wrapper self-sufficient
  # even if the outer shell predates the WT_SESSION inference in shellrc.
  # Setting COLORTERM here is consistent with already opting into truecolor
  # via CLAUDE_CODE_TMUX_TRUECOLOR=1 below.
  # Subshell so the pre-cd for `--resume <id>` doesn't leak to the caller.
  (
    export COLORTERM=truecolor
    [ -n "$_sess_cwd" ] && [ -d "$_sess_cwd" ] && cd "$_sess_cwd"
    tmux new-session -s "claude-$$" \
      -e CLAUDE_CODE_TMUX_TRUECOLOR=1 \
      -e CLAUDE_EXIT_FILE="$exit_capture" \
      "$cmd" \
      \; set status-style "bg=colour238 fg=colour250" \; set destroy-unattached on \
      \; set @claude-running 1
  )
  if [ -s "$exit_capture" ]; then
    local sid
    sid=$(grep -o '"session_id":"[^"]*"' "$exit_capture" | head -1)
    sid=${sid#'"session_id":"'}
    sid=${sid%'"'}
    if [ -n "$sid" ]; then
      printf '\n\033[90mResume this session with:\n  claude --resume %s\n\033[0m' "$sid"
    fi
  fi
  rm -f "$exit_capture"
}

