# Auto-update dotfiles
_dotfiles_update() {
  local dotfiles="$HOME/.dotfiles"
  local backup="$dotfiles/backup"

  GIT_TERMINAL_PROMPT=0 git -C "$dotfiles" fetch --quiet 2>/dev/null || return

  local changed
  changed=$(git -C "$dotfiles" diff --name-only HEAD..@{u} 2>/dev/null)
  [ -z "$changed" ] && return

  local timestamp
  timestamp=$(date +%s)
  mkdir -p "$backup"

  printf '%s\n' "$changed" | while IFS= read -r f; do
    [ -f "$dotfiles/$f" ] || continue
    bname="${f//\//_}"
    cp "$dotfiles/$f" "$backup/${bname}.${timestamp}.bak"
    ls "$backup/${bname}".*.bak 2>/dev/null | sort | head -n -5 | while IFS= read -r old; do
      rm -f "$old"
    done
  done

  GIT_TERMINAL_PROMPT=0 git -C "$dotfiles" pull --ff-only --quiet 2>/dev/null
}
if [ -d "$HOME/.dotfiles/.git" ]; then
  (_dotfiles_update &)
fi
unset -f _dotfiles_update

# Colorized ls
export CLICOLOR=1
export LSCOLORS=Exfxcxdxcxegedabagaced

# Aliases
alias ll='ls -la'
alias l='ls -l'
alias cd='z'
alias ..='z ..'
alias ...='z ../..'
alias grep='grep --color=auto'
alias mkdir='mkdir -pv'
alias path='echo $PATH | tr ":" "\n"'
alias hzr='ssh harrison@REDACTED'

# Claude
export PATH="$HOME/.local/bin:$PATH"
export ENABLE_LSP_TOOL=1

# GitHub
export GITHUB_PERSONAL_ACCESS_TOKEN="$(gh auth token)"

# bun
[ -s "$HOME/.bun/_bun" ] && . "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# deno
[ -f "$HOME/.deno/env" ] && . "$HOME/.deno/env"
