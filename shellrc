# Prepend to PATH only if not already present (avoids stacking on reload)
path_prepend() {
  case ":$PATH:" in
    *:"$1":*) ;;
    *) export PATH="$1:$PATH" ;;
  esac
}

# SSH agent (keychain) — use per-user binary to avoid clashing with 1Password etc.
if [ -x "$HOME/.local/bin/keychain" ]; then
  eval "$("$HOME/.local/bin/keychain" --eval id_ed25519)"
fi

# Resolve where the dotfiles repo lives by following the ~/.shellrc symlink.
# install.sh always symlinks ~/.shellrc to <repo>/shellrc (with an absolute
# target), so the parent of the link target is the repo root. Falls back to
# ~/.dotfiles if ~/.shellrc isn't a symlink (e.g., copied rather than linked).
if [ -L "$HOME/.shellrc" ]; then
  _dotfiles_dir=$(cd "$HOME" 2>/dev/null && cd "$(dirname "$(readlink "$HOME/.shellrc")")" 2>/dev/null && pwd)
fi
: "${_dotfiles_dir:=$HOME/.dotfiles}"

# Auto-update dotfiles (set DOTFILES_AUTO_UPDATE=1 in ~/.zshrc.local or ~/.bashrc.local)
_dotfiles_update() {
  local dotfiles="$_dotfiles_dir"
  local backup="$dotfiles/backup"
  local msg="$dotfiles/.update-msg"

  GIT_TERMINAL_PROMPT=0 git -C "$dotfiles" fetch --quiet 2>/dev/null || return

  local changed
  changed=$(git -C "$dotfiles" diff --name-only HEAD..@{u} 2>/dev/null)
  [ -z "$changed" ] && return

  local commit_count plural=""
  commit_count=$(git -C "$dotfiles" rev-list --count HEAD..@{u} 2>/dev/null)
  [ "$commit_count" != "1" ] && plural="s"

  local timestamp
  timestamp=$(date +%s)
  mkdir -p "$backup"

  printf '%s\n' "$changed" | while IFS= read -r f; do
    [ -f "$dotfiles/$f" ] || continue
    local bname="${f//\//_}"
    cp "$dotfiles/$f" "$backup/${bname}.${timestamp}.bak"
    local count=$(ls "$backup/${bname}".*.bak 2>/dev/null | wc -l)
    if [ "$count" -gt 5 ]; then
      ls "$backup/${bname}".*.bak 2>/dev/null | sort | head -n $(( count - 5 )) | while IFS= read -r old; do
        rm -f "$old"
      done
    fi
  done

  GIT_TERMINAL_PROMPT=0 git -C "$dotfiles" pull --ff-only --quiet 2>/dev/null \
    && printf '\033[1;34m[dotfiles]\033[0m Updated from remote \033[38;5;240m(%s commit%s)\033[0m\n' "$commit_count" "$plural" > "$msg"
}
# Execution is deferred to zshrc/bashrc (after local rc sets DOTFILES_AUTO_UPDATE)

# Warn if install.sh hasn't been re-run since the migration system was added.
# Either condition means `git pull` won't trigger pending migrations.
if [ -d "$_dotfiles_dir/.git" ] && \
   { [ ! -L "$_dotfiles_dir/.git/hooks/post-merge" ] || [ ! -f "$HOME/.dotfiles-migrated" ]; }; then
  _install_path="$_dotfiles_dir/install.sh"
  case "$_install_path" in
    "$HOME"/*) _install_path="~${_install_path#$HOME}" ;;
  esac
  printf '\033[1;33m[dotfiles]\033[0m You need to run install.sh again to setup migrations \033[38;5;240m(%s)\033[0m\n' "$_install_path" >&2
  unset _install_path
fi

# COLORTERM doesn't survive SSH (sshd only accepts LANG/LC_*), but TERM does.
# Infer truecolor from terminal-specific TERM values before falling back.
if [ -z "$COLORTERM" ]; then
  case "$TERM" in
    xterm-ghostty|xterm-kitty|alacritty|wezterm) export COLORTERM=truecolor ;;
    tmux-*|screen-*) export COLORTERM=truecolor ;;
  esac
fi

# If the terminfo entry for TERM is missing, fall back to xterm-256color
# (common over SSH when the remote lacks e.g. xterm-ghostty terminfo)
if ! infocmp "$TERM" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

# Claude Code downgrades to 256 colors inside tmux by default
[ -n "$TMUX" ] && export CLAUDE_CODE_TMUX_TRUECOLOR=1

# Colorized ls
export CLICOLOR=1
export LSCOLORS=Exfxcxdxcxegedabagaced

alias ll='ls -la'
alias l='ls -l'

# Aliases
alias gs='git status'
alias cd='z'
alias ..='z ..'
alias ...='z ../..'
alias grep='grep --color=auto'
alias mkdir='mkdir -pv'
alias path='echo $PATH | tr ":" "\n"'
reload() {
  if [ -n "$BASH_VERSION" ]; then
    source ~/.bashrc
  else
    source ~/.zshrc
  fi
}

# Functions
extract() {
  if [ ! -f "$1" ]; then
    echo "extract: '$1' is not a file" >&2
    return 1
  fi
  case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz)  tar xzf "$1" ;;
    *.tar.xz)  tar xJf "$1" ;;
    *.tar)     tar xf "$1" ;;
    *.bz2)     bunzip2 "$1" ;;
    *.gz)      gunzip "$1" ;;
    *.zip)     unzip "$1" ;;
    *.Z)       uncompress "$1" ;;
    *.7z)      7z x "$1" ;;
    *.rar)     unrar x "$1" ;;
    *) echo "extract: unsupported format '$1'" >&2; return 1 ;;
  esac
}

# Claude
path_prepend "$HOME/.local/bin"
export ENABLE_LSP_TOOL=1

# Wrap `claude` in a chrome-less tmux session when launched from a bare
# shell so the TUI gets clean framing (no status bar, no window list).
# Inside an existing tmux session, run claude directly — the user's
# manual session is intentional and should keep its normal lifecycle.
# Unique PID-suffixed session names avoid duplicate-session errors;
# destroy-unattached on makes the session die as soon as claude exits
# or the terminal closes, matching an unwrapped claude's lifecycle.
claude() {
  if [ -n "$TMUX" ]; then
    command claude "$@"
  else
    local claude_bin
    claude_bin=$(unset -f claude 2>/dev/null; command -v claude) || { echo "claude: not found" >&2; return 127; }
    local cmd="$claude_bin"
    [ $# -gt 0 ] && cmd="$cmd $(printf '%q ' "$@")"
    # `-e` is required (not a plain `VAR=val tmux ...` prefix) because tmux
    # only propagates vars in `update-environment` from the calling shell into
    # new sessions; `CLAUDE_CODE_TMUX_TRUECOLOR` isn't on that list, so it'd
    # be dropped whenever the wrapper attaches to an already-running server.
    tmux new-session -s "claude-$$" -e CLAUDE_CODE_TMUX_TRUECOLOR=1 "$cmd" \; set status off \; set destroy-unattached on
  fi
}

# bun (completions are zsh-specific)
[ -n "$ZSH_VERSION" ] && [ -s "$HOME/.bun/_bun" ] && . "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
path_prepend "$BUN_INSTALL/bin"

# deno
[ -f "$HOME/.deno/env" ] && . "$HOME/.deno/env"

# rust
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# go
[ -d /usr/local/go/bin ] && path_prepend "/usr/local/go/bin"
