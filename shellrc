alias path='echo $PATH | tr ":" "\n"'
reload() {
  if [ -n "$BASH_VERSION" ]; then
    source ~/.bashrc
  else
    source ~/.zshrc
  fi
}

# Functions
extract() {
  if [ ! -f "$1" ]; then
    echo "extract: '$1' is not a file" >&2
    return 1
  fi
  case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz)  tar xzf "$1" ;;
    *.tar.xz)  tar xJf "$1" ;;
    *.tar)     tar xf "$1" ;;
    *.bz2)     bunzip2 "$1" ;;
    *.gz)      gunzip "$1" ;;
    *.zip)     unzip "$1" ;;
    *.Z)       uncompress "$1" ;;
    *.7z)      7z x "$1" ;;
    *.rar)     unrar x "$1" ;;
    *) echo "extract: unsupported format '$1'" >&2; return 1 ;;
  esac
}

# Git prompt info (used by both zsh PROMPT and bash PS1)
_git_branch_info() {
  local branch dirty=""
  branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
  git diff --quiet 2>/dev/null || dirty="*"
  [ -z "$dirty" ] && [ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ] && dirty="*"
  local color_code
  if [ -n "$dirty" ]; then
    color_code="210"
  elif [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    color_code="218"
  else
    color_code="2"
  fi
  if [ -n "$ZSH_VERSION" ]; then
    printf ' %%F{%s}(%s%s)%%f' "$color_code" "$dirty" "$branch"
  else
    printf ' \001\033[38;5;%sm\002(%s%s)\001\033[0m\002' "$color_code" "$dirty" "$branch"
  fi
}

# Claude
path_prepend "$HOME/.local/bin"
export ENABLE_LSP_TOOL=1

# Wrap `claude` in a chrome-less tmux session when launched from a bare
# shell so the TUI gets clean framing (no status bar, no window list).
# Inside an existing tmux session, run claude directly — the user's
# manual session is intentional and should keep its normal lifecycle.
# Unique PID-suffixed session names avoid duplicate-session errors;
# destroy-unattached on makes the session die as soon as claude exits
# or the terminal closes, matching an unwrapped claude's lifecycle.
claude() {
  if [ -n "$TMUX" ]; then
    command claude "$@"
  else
    local claude_bin
    claude_bin=$(unset -f claude 2>/dev/null; command -v claude) || { echo "claude: not found" >&2; return 127; }
    local cmd="$claude_bin"
    [ $# -gt 0 ] && cmd="$cmd $(printf '%q ' "$@")"
    # Claude's farewell text (resume hint, cost summary) is lost when
    # the tmux session is destroyed. A SessionEnd hook in settings.json
    # dumps the session payload to $CLAUDE_EXIT_FILE; we parse the session
    # ID from it after tmux returns.
    local exit_capture
    exit_capture=$(mktemp "${TMPDIR:-/tmp}/claude-exit.XXXXXX") || return 1
    # `-e` is required (not a plain `VAR=val tmux ...` prefix) because tmux
    # only propagates vars in `update-environment` from the calling shell into
    # new sessions; `CLAUDE_CODE_TMUX_TRUECOLOR` isn't on that list, so it'd
    # be dropped whenever the wrapper attaches to an already-running server.
    tmux new-session -s "claude-$$" \
      -e CLAUDE_CODE_TMUX_TRUECOLOR=1 \
      -e CLAUDE_EXIT_FILE="$exit_capture" \
      "$cmd" \
      \; set status off \; set destroy-unattached on
    if [ -s "$exit_capture" ]; then
      local sid
      sid=$(grep -o '"session_id":"[^"]*"' "$exit_capture" | head -1)
      sid=${sid#'"session_id":"'}
      sid=${sid%'"'}
      # Only show the hint if the session had real content (not a blank exit).
      if [ -n "$sid" ]; then
        local jsonl
        jsonl=$(ls "$HOME/.claude/projects"/*/"$sid.jsonl" 2>/dev/null | head -1)
        if [ -n "$jsonl" ] && [ "$(wc -l < "$jsonl")" -gt 1 ]; then
          printf '\n\033[90mResume this session with:\n  claude --resume %s\n\033[0m' "$sid"
        fi
      fi
    fi
    rm -f "$exit_capture"
  fi
}

